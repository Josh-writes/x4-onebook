{
  "name": "x4-onebook-shelf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others -n server,client -c cyan,magenta \"nodemon server/index.js\" \"cd client && npm run dev\"",
    "start": "node server/index.js",
    "build": "cd client && npm run build",
    "postinstall": "npm install --prefix client"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "htmlparser2": "^9.1.0",
    "multer": "^1.4.5-lts.1",
    "opentype.js": "^1.3.4",
    "serialport": "^12.0.0",
    "sharp": "^0.33.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  }
}
